# Browser.cash API Key (Required)
# Get one at https://browser.cash
BROWSER_API_KEY=

# Datalab API Key for PDF processing (Optional)
# If not set, PDF processing will be disabled
DATALAB_API_KEY=

# Server Configuration
PORT=8085
HOST=0.0.0.0
DEBUG_LOG=false

# Services
SERP_SERVICE_URL=http://localhost:8080

# Session Pool Config
POOL_SIZE=3

# Crawler Tuning
CRAWL_TABS_PER_SESSION=5
CRAWL_MIN_CONTENT_LENGTH=200
CRAWL_NAVIGATION_TIMEOUT_MS=10000
CRAWL_SLOW_TIMEOUT_MS=20000
CRAWL_JITTER_MS=0